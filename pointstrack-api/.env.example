# ---- Server ----
PORT=4000
NODE_ENV=development
# Public base URL of this API (used to build local upload URLs)
API_URL=http://localhost:4000
# Comma-separated list of allowed origins for CORS (web admin, expo dev, etc.)
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Local docker postgres (see docker-compose.yml). Railway will inject its own DATABASE_URL.
DATABASE_URL=postgres://pointstrack:pointstrack@localhost:5432/pointstrack
# Connection pool size. Keep small on tiny instances; raise behind pgBouncer/Neon
# pooling when running multiple API nodes.
DB_POOL_MAX=10

# ---- Auth (JWT) ----
# Generate strong values: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- Storage (S3-compatible: Cloudflare R2, Supabase, Backblaze B2, MinIO) ----
# Leave everything blank to store uploads on local disk (./uploads served at /uploads).
# Provide credentials + a bucket + an account id (R2) OR an explicit S3_ENDPOINT.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for serving objects.
#   R2:        your R2 public bucket URL / custom domain
#   Supabase:  https://<project-ref>.supabase.co/storage/v1/object/public/<bucket>
R2_PUBLIC_URL=

# Cloudflare R2 only (needs a card to enable). Endpoint is derived from this.
R2_ACCOUNT_ID=

# Non-R2 providers (no card needed) — set S3_ENDPOINT + S3_REGION instead of R2_ACCOUNT_ID:
#   Supabase:    S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3   S3_REGION=<your region>
#   Backblaze B2: S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com           S3_REGION=us-west-004
S3_ENDPOINT=
S3_REGION=auto
