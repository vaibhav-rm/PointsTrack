# ---- Server ----
PORT=4000
NODE_ENV=development
# Public base URL of this API (used to build local upload URLs)
API_URL=http://localhost:4000
# Comma-separated list of allowed origins for CORS (web admin, expo dev, etc.)
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Local docker postgres (see docker-compose.yml). Railway will inject its own DATABASE_URL.
DATABASE_URL=postgres://pointstrack:pointstrack@localhost:5432/pointstrack

# ---- Auth (JWT) ----
# Generate strong values: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- Storage ----
# Leave R2_* blank to store uploads on local disk (./uploads served at /uploads).
# Set these to switch to Cloudflare R2 (or any S3-compatible store) with zero code changes.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for serving objects (R2 public bucket URL or custom domain)
R2_PUBLIC_URL=
