digraph Scalability {
  rankdir=TB;
  bgcolor="white";
  fontname="Liberation Sans";
  labelloc="t";
  label=<<FONT POINT-SIZE="22"><B>Scaling Topology</B></FONT><BR/><FONT POINT-SIZE="11" COLOR="#64748B">Stateless API → scale horizontally behind a load balancer · additive path to 50k+</FONT><BR/> >;
  node [fontname="Liberation Sans", shape=box, style="rounded,filled", fontsize=11, margin="0.16,0.1", color="#CBD5E1"];
  edge [fontname="Liberation Sans", fontsize=10, color="#475569", penwidth=1.3, arrowsize=0.8];
  nodesep=0.5; ranksep=0.7;

  clients [label=<<B>Mobile + Web clients</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">JWT in every request — no server session</FONT>>, fillcolor="#EEF2FF", color="#6366F1"];
  lb [label=<<B>Load balancer / HTTPS</B>>, fillcolor="#E0E7FF", color="#4F46E5"];

  subgraph cluster_api {
    label=<<B>N stateless API instances (scale out →)</B>>; fontname="Liberation Sans"; fontsize=12; fontcolor="#334155";
    style="rounded,filled"; color="#C7D2FE"; fillcolor="#F5F7FF";
    a1 [label=<<B>api #1</B>>, fillcolor="#4F46E5", fontcolor="white", color="#3730A3"];
    a2 [label=<<B>api #2</B>>, fillcolor="#4F46E5", fontcolor="white", color="#3730A3"];
    a3 [label=<<B>api #N</B>>, fillcolor="#4F46E5", fontcolor="white", color="#3730A3"];
  }

  pooler [label=<<B>Connection pooler</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">pgBouncer / Neon pooling</FONT>>, fillcolor="#E0F2FE", color="#0369A1"];
  pg [label=<<B>Managed PostgreSQL</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">Neon / Supabase · read replicas</FONT>>, shape=cylinder, fillcolor="#E0F2FE", color="#0369A1"];
  obj [label=<<B>Object storage (S3 / R2)</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">shared — lets API stay stateless</FONT>>, fillcolor="#FEF9C3", color="#CA8A04"];

  redis [label=<<B>Redis (additive)</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">shared rate-limit store</FONT>>, fillcolor="#FFE4E6", color="#E11D48", style="rounded,filled,dashed"];
  queue [label=<<B>Job queue (additive)</B><BR/><FONT POINT-SIZE="9" COLOR="#475569">bulk push broadcasts 50k+</FONT>>, fillcolor="#FFE4E6", color="#E11D48", style="rounded,filled,dashed"];

  clients -> lb;
  lb -> a1; lb -> a2; lb -> a3;
  a1 -> pooler; a2 -> pooler; a3 -> pooler;
  pooler -> pg;
  a2 -> obj [color="#CA8A04"];
  a1 -> redis [style=dashed, color="#E11D48"];
  a3 -> queue [style=dashed, color="#E11D48"];

  { rank=same; a1; a2; a3; }
  { rank=same; redis; pooler; queue; }
}
